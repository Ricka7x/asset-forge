{
  "name": "asset-forge",
  "version": "0.2.3",
  "description": "The complete asset toolkit for developers",
  "bin": {
    "asset-forge": "./dist/asset-forge",
    "forge": "./dist/asset-forge"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build ./src/cli.ts --compile --outfile dist/asset-forge && bun link",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64",
    "build:darwin-arm64": "bun build ./src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/asset-forge-darwin-arm64",
    "build:darwin-x64": "bun build ./src/cli.ts --compile --target=bun-darwin-x64 --outfile dist/asset-forge-darwin-x64",
    "build:linux-x64": "bun build ./src/cli.ts --compile --target=bun-linux-x64 --outfile dist/asset-forge-linux-x64",
    "test": "bun run build && bun test tests/smoke.test.ts",
    "test:integration": "bun run build && bun test tests/integration.test.ts",
    "test:all": "bun run build && bun test",
    "release": "bash release.sh"
  },
  "devDependencies": {
    "bun-types": "^1.3.11"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "citty": "^0.1.6"
  }
}
