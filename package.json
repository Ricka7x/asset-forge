{
  "name": "asset-forge",
  "version": "0.3.1",
  "description": "The complete asset toolkit for developers",
  "bin": {
    "asset-forge": "./dist/cli.js",
    "forge": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun run build.ts",
    "build:watch": "tsup --watch",
    "test": "npm run build && bun test tests/smoke.test.ts",
    "test:integration": "npm run build && bun test tests/integration.test.ts",
    "test:all": "npm run build && bun test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.9",
    "bun-types": "^1.3.11"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "blurhash": "^2.0.5",
    "chalk": "^5.3.0",
    "citty": "^0.2.1",
    "ffmpeg-static": "^5.3.0",
    "file-type": "16.5.4",
    "fluent-ffmpeg": "^2.1.3",
    "image-hash": "^7.0.1",
    "js-yaml": "^4.1.1",
    "node-vibrant": "^4.0.4",
    "sharp": "^0.34.5",
    "tsup": "^8.5.1"
  }
}
